<Window x:Class="CardRPG.UI.AchievementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Achievements"
        WindowState="Maximized"
        WindowStyle="None"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="Black">

    <Grid>
        <Image Source="Assets/bg_city.avif" Stretch="Fill"/>
        <Rectangle Fill="#DD0A0A10"/>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="ACHIEVEMENTS" FontSize="28" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,4">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFD700" Offset="0"/>
                        <GradientStop Color="#FFA500" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FFD700" BlurRadius="16" ShadowDepth="0" Opacity="0.4"/>
                </TextBlock.Effect>
            </TextBlock>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,12">
                <TextBlock x:Name="ProgressTxt" Text="0 / 22 completed" Foreground="#BBAA88" FontSize="14"/>
            </StackPanel>

            <Border Grid.Row="2" Style="{StaticResource RpgPanel}" Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="AchievementList"/>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource RpgPanel}" Padding="10,6" Margin="0,10,0,0">
                <DockPanel>
                    <TextBlock x:Name="StatusTxt" Foreground="LimeGreen" FontSize="13" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="Close" Width="100" Height="42" FontSize="14"
                            Style="{StaticResource RpgSubtleButton}" Click="CloseBtn_Click"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
