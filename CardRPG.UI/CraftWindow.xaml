<Window x:Class="CardRPG.UI.CraftWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Card Forge"
        WindowState="Maximized"
        WindowStyle="None"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="Black">

    <Grid>
        <Image Source="Assets/bg_city.avif" Stretch="Fill"/>
        <Rectangle Fill="#DD100808"/>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="CARD FORGE" FontSize="28" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,4">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF6633" Offset="0"/>
                        <GradientStop Color="#FFD700" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FF6633" BlurRadius="16" ShadowDepth="0" Opacity="0.4"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Grid.Row="1" Text="Combine 2 identical cards to forge a stronger version."
                       Foreground="#AA8866" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,12"/>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource RpgPanel}" Padding="8" Margin="0,0,6,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="YOUR CARDS (select to craft)"
                                   Foreground="#FFCC44" FontSize="13" FontWeight="Bold" Margin="0,0,0,6"/>
                        <ListBox x:Name="CardList" Background="Transparent" Foreground="White"
                                 FontSize="12" BorderThickness="0"
                                 SelectionChanged="CardList_SelectionChanged"/>
                    </DockPanel>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="=>" Foreground="#FFD700" FontSize="36" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="2" Style="{StaticResource RpgPanel}" Padding="12" Margin="6,0,0,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="RESULT" Foreground="#888" FontSize="12" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="ResultNameTxt" Text="---" Foreground="White" FontSize="18"
                                   FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ResultDetailTxt" Text="" Foreground="#AAAAAA" FontSize="13"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                                   Margin="0,6,0,0"/>
                        <TextBlock x:Name="CostTxt" Text="" Foreground="#FFD700" FontSize="14"
                                   FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                <TextBlock Text="Gold: " Foreground="#BBAA88" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="GoldTxt" Text="0" Foreground="#FFD700" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,20,0"/>
                <Button x:Name="CraftBtn" Content="FORGE" Width="160" Height="46"
                        Style="{StaticResource RpgRedButton}" FontSize="15"
                        Click="CraftBtn_Click" IsEnabled="False"/>
            </StackPanel>

            <Border Grid.Row="4" Style="{StaticResource RpgPanel}" Padding="10,6" Margin="0,10,0,0">
                <DockPanel>
                    <TextBlock x:Name="StatusTxt" Foreground="LimeGreen" FontSize="13" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="Close" Width="100" Height="42" FontSize="14"
                            Style="{StaticResource RpgSubtleButton}" Click="CloseBtn_Click"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
