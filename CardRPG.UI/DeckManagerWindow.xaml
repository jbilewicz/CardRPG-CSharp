<Window x:Class="CardRPG.UI.DeckManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Deck Manager" Height="680" Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Black">

    <Grid>
        <Image Source="Assets/bg_city.avif" Stretch="Fill"
               HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        <Rectangle Fill="#DD0A0A15"/>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="DECK MANAGER" FontSize="28" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,4">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFCC44" Offset="0"/>
                        <GradientStop Color="#FF8800" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FFCC44" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
                </TextBlock.Effect>
            </TextBlock>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,0,0,10">
                <TextBlock Text="Deck: " Foreground="#8B8B7A" FontSize="14"/>
                <TextBlock x:Name="DeckCountTxt" Text="0 cards" Foreground="#FFCC44"
                           FontSize="14" FontWeight="Bold"/>
                <TextBlock Text="     Gold: " Foreground="#8B8B7A" FontSize="14" Margin="16,0,0,0"/>
                <TextBlock x:Name="GoldTxt" Text="0" Foreground="#FFD700"
                           FontSize="14" FontWeight="Bold"/>
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource RpgPanel}" Padding="10"
                        Margin="0,0,10,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="YOUR CARDS" Foreground="Gold"
                                   FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <WrapPanel x:Name="CardPanel" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource RpgPanel}" Padding="12">
                    <StackPanel>
                        <TextBlock Text="SELECTED CARD" Foreground="Gold"
                                   FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                        <Border x:Name="SelectedCardBorder" Style="{StaticResource RpgPanel}"
                                Padding="10" Margin="0,0,0,10" MinHeight="120">
                            <StackPanel>
                                <TextBlock x:Name="SelNameTxt" Text="Select a card..."
                                           FontSize="16" FontWeight="Bold" Foreground="White"/>
                                <TextBlock x:Name="SelTypeTxt" Foreground="Gray" FontSize="12"
                                           Margin="0,4,0,0"/>
                                <TextBlock x:Name="SelDescTxt" Foreground="#CCCCCC" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                                <TextBlock x:Name="SelRarityTxt" FontWeight="Bold" FontSize="12"
                                           Margin="0,4,0,0"/>
                                <TextBlock x:Name="SelUpgradeTxt" Foreground="#FFCC44" FontSize="12"
                                           FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Button x:Name="UpgradeBtn" Content="UPGRADE" Height="44"
                                Style="{StaticResource RpgGreenButton}" FontSize="14"
                                Click="UpgradeButton_Click" Margin="0,0,0,8"/>

                        <Button x:Name="EvolveBtn" Content="✨ EVOLVE" Height="44"
                                FontSize="14" Visibility="Collapsed"
                                Click="EvolveButton_Click" Margin="0,0,0,8">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource RpgButton}">
                                    <Setter Property="Foreground" Value="#FFD700"/>
                                    <Setter Property="BorderBrush" Value="#FFD700"/>
                                </Style>
                            </Button.Style>
                            <Button.Effect>
                                <DropShadowEffect Color="#FFD700" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                            </Button.Effect>
                        </Button>

                        <Button x:Name="RemoveBtn" Content="REMOVE FROM DECK" Height="44"
                                Style="{StaticResource RpgRedButton}" FontSize="14"
                                Click="RemoveButton_Click" Margin="0,0,0,8"/>

                        <TextBlock x:Name="InfoTxt" Foreground="Gray" FontSize="11"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="3" Style="{StaticResource RpgPanel}"
                    Padding="10,6" Margin="0,10,0,0">
                <DockPanel>
                    <TextBlock x:Name="StatusTxt" Foreground="LimeGreen" FontSize="13"
                               VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="Close" Width="90" Height="38"
                            Style="{StaticResource RpgSubtleButton}"
                            Click="CloseButton_Click"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
