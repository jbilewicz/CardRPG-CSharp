<Window x:Class="CardRPG.UI.EnchantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enchanting"
        WindowState="Maximized"
        WindowStyle="None"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="Black">

    <Grid>
        <Image Source="Assets/bg_city.avif" Stretch="Fill"/>
        <Rectangle Fill="#DD0D0818"/>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="ENCHANTING" FontSize="28" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,4">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#AA44FF" Offset="0"/>
                        <GradientStop Color="#FF44AA" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                <TextBlock.Effect>
                    <DropShadowEffect Color="#AA44FF" BlurRadius="16" ShadowDepth="0" Opacity="0.4"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Grid.Row="1" Text="Imbue your weapon with elemental power."
                       Foreground="#8866AA" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,16"/>

            <Border Grid.Row="2" Style="{StaticResource RpgPanel}" Padding="20,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <TextBlock Text="Weapon: " Foreground="#8B8B7A" FontSize="16"/>
                        <TextBlock x:Name="WeaponTxt" Text="None" Foreground="LightBlue" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <TextBlock Text="Current Enchant: " Foreground="#8B8B7A" FontSize="14"/>
                        <TextBlock x:Name="EnchantTxt" Text="None" Foreground="#AA44FF" FontSize="14" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="Gold: " Foreground="#BBAA88" FontSize="15" FontWeight="Bold"/>
                        <TextBlock x:Name="GoldTxt" Text="0" Foreground="#FFD700" FontSize="15" FontWeight="Bold"/>
                    </StackPanel>

                    <TextBlock Text="Choose Enchantment (50 Gold each):" Foreground="#888" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <WrapPanel HorizontalAlignment="Center">
                        <Button Content="Burn (+3 fire/turn)" Width="180" Height="42" Margin="6"
                                Style="{StaticResource RpgRedButton}" FontSize="12" Tag="Burn"
                                Click="EnchantBtn_Click"/>
                        <Button Content="Poison (+2 poison/turn)" Width="180" Height="42" Margin="6"
                                Style="{StaticResource RpgGreenButton}" FontSize="12" Tag="Poison"
                                Click="EnchantBtn_Click"/>
                        <Button Content="Lifesteal (heal 50%)" Width="180" Height="42" Margin="6"
                                Style="{StaticResource RpgTealButton}" FontSize="12" Tag="Lifesteal"
                                Click="EnchantBtn_Click"/>
                        <Button Content="Bleed (+2 bleed/turn)" Width="180" Height="42" Margin="6"
                                Style="{StaticResource RpgButton}" FontSize="12" Tag="Bleed"
                                Click="EnchantBtn_Click"/>
                    </WrapPanel>

                    <Button Content="Remove Enchantment (free)" Width="220" Height="42" Margin="0,12,0,0"
                            Style="{StaticResource RpgSubtleButton}" FontSize="13"
                            Click="RemoveEnchant_Click" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource RpgPanel}" Padding="10,6" Margin="0,12,0,0">
                <DockPanel>
                    <TextBlock x:Name="StatusTxt" Foreground="LimeGreen" FontSize="13" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="Close" Width="100" Height="42" FontSize="14"
                            Style="{StaticResource RpgSubtleButton}" Click="CloseBtn_Click"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
