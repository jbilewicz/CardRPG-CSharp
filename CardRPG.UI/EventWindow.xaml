<Window x:Class="CardRPG.UI.EventWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Random Event" Height="420" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Black">

    <Grid>
        <Image Source="Assets/bg_combat.png" Stretch="Fill"
               HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        <Rectangle Fill="#DD0A0A15"/>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" x:Name="TitleTxt" Text="EVENT" FontSize="26" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,10">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFD700" Offset="0"/>
                        <GradientStop Color="#FFA500" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FFD700" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/>
                </TextBlock.Effect>
            </TextBlock>

            <Border Grid.Row="1" Style="{StaticResource RpgPanel}" Padding="16,12"
                    Margin="0,0,0,14">
                <TextBlock x:Name="DescTxt" Text="" FontSize="15" Foreground="#DDDDDD"
                           TextWrapping="Wrap" TextAlignment="Center" LineHeight="22"/>
            </Border>

            <StackPanel Grid.Row="2" VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <Button x:Name="ChoiceABtn" Width="340" Height="48" Margin="0,0,0,10"
                        Style="{StaticResource RpgGreenButton}" FontSize="14"
                        Click="ChoiceA_Click"/>
                <Button x:Name="ChoiceBBtn" Width="340" Height="48"
                        Style="{StaticResource RpgButton}" FontSize="14"
                        Click="ChoiceB_Click"/>
            </StackPanel>

            <Border Grid.Row="3" x:Name="ResultPanel" Style="{StaticResource RpgPanel}"
                    Padding="12,8" Margin="0,10,0,0" Visibility="Collapsed">
                <DockPanel>
                    <TextBlock x:Name="ResultTxt" FontSize="14" FontWeight="Bold"
                               Foreground="LimeGreen" TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="Continue" Width="100" Height="36"
                            Style="{StaticResource RpgButton}" FontSize="13"
                            Click="ContinueButton_Click"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
