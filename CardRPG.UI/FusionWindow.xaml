<Window x:Class="CardRPG.UI.FusionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Card Forge" Height="700" Width="950"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Black">

    <Grid>
        <Image Source="Assets/bg_city.avif" Stretch="Fill"
               HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        <Rectangle Fill="#DD0A0A15"/>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="CARD FORGE" FontSize="28" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,4">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF8800" Offset="0"/>
                        <GradientStop Color="#FFCC44" Offset="0.5"/>
                        <GradientStop Color="#FF8800" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FF8800" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock Grid.Row="1" Text="Combine 2 cards of the same rarity to forge 1 card of higher rarity!"
                       FontSize="12" Foreground="#8B8B7A" HorizontalAlignment="Center" Margin="0,0,0,6"/>

            <Border Grid.Row="2" Style="{StaticResource RpgPanel}" Padding="12,8" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Gold: " Foreground="#8B8B7A" FontSize="14"/>
                    <TextBlock x:Name="GoldTxt" Text="0" Foreground="#FFD700" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="      Slot 1: " Foreground="#8B8B7A" FontSize="14" Margin="20,0,0,0"/>
                    <TextBlock x:Name="Slot1Txt" Text="(empty)" Foreground="#FFCC44" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="  +  Slot 2: " Foreground="#8B8B7A" FontSize="14"/>
                    <TextBlock x:Name="Slot2Txt" Text="(empty)" Foreground="#FFCC44" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="      Cost: " Foreground="#8B8B7A" FontSize="14" Margin="20,0,0,0"/>
                    <TextBlock x:Name="CostTxt" Text="-" Foreground="OrangeRed" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource RpgPanel}" Padding="10" Margin="0,0,10,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="YOUR CARDS (click to select)" Foreground="Gold"
                                   FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <WrapPanel x:Name="CardPanel" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource RpgPanel}" Padding="12">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="FUSION" Foreground="Gold" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>

                        <TextBlock x:Name="FusionInfoTxt" Text="Select 2 cards of the same rarity to fuse."
                                   Foreground="#999" FontSize="11" TextWrapping="Wrap" TextAlignment="Center"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Fusion Costs:" Foreground="#8B8B7A" FontSize="11" HorizontalAlignment="Center"/>
                        <TextBlock Text="Common → Uncommon: 50g" Foreground="#44FF44" FontSize="11" HorizontalAlignment="Center"/>
                        <TextBlock Text="Uncommon → Rare: 100g" Foreground="#44AAFF" FontSize="11" HorizontalAlignment="Center"/>
                        <TextBlock Text="Rare → Legendary: 250g" Foreground="#FFAA00" FontSize="11" HorizontalAlignment="Center"
                                   Margin="0,0,0,14"/>

                        <Button x:Name="FuseBtn" Content="FUSE!" Height="48"
                                Style="{StaticResource RpgRedButton}" FontSize="15"
                                IsEnabled="False" Click="FuseButton_Click" Margin="0,0,0,8"/>

                        <Button Content="CLEAR" Height="36"
                                Style="{StaticResource RpgSubtleButton}" FontSize="12"
                                Click="ClearButton_Click"/>

                        <TextBlock x:Name="StatusTxt" Foreground="LimeGreen" FontSize="12"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="4" Style="{StaticResource RpgPanel}" Padding="10,6" Margin="0,8,0,0">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Close" Width="90" Height="38"
                            Style="{StaticResource RpgSubtleButton}" Click="CloseButton_Click"/>
                    <TextBlock x:Name="ResultTxt" Foreground="#FFCC44" FontSize="13"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
