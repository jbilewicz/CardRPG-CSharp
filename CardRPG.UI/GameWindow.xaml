<Window x:Class="CardRPG.UI.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CardRPG - City Hub"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Image Source="Assets/bg_city.avif" Stretch="Fill" Grid.RowSpan="3"
               HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        <Rectangle Fill="#66000000" Grid.RowSpan="3"/>

        <!-- Settings gear button -->
        <Button x:Name="SettingsBtn" Content="⚙️" FontSize="24"
                Width="46" Height="46"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,12,16,0" Panel.ZIndex="20" Grid.RowSpan="3"
                Background="#44000000" Foreground="#FFD700"
                BorderBrush="#55FFD700" BorderThickness="1"
                Cursor="Hand" ToolTip="Audio Settings"
                Click="SettingsBtn_Click"/>

        <!-- Settings overlay panel -->
        <Border x:Name="SettingsPanel" Grid.RowSpan="3" Panel.ZIndex="30"
                Background="#DD111118" CornerRadius="12"
                Width="360" Height="380"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,66,16,0" Visibility="Collapsed">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#B8860B" Offset="0"/>
                    <GradientStop Color="#FFD700" Offset="0.5"/>
                    <GradientStop Color="#B8860B" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.BorderThickness>2</Border.BorderThickness>
            <StackPanel Margin="20,16">
                <TextBlock Text="⚙ Audio Settings" FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,18">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFD700" Offset="0"/>
                            <GradientStop Color="#FFA500" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <TextBlock Text="Master Volume" Foreground="#C0B090" FontSize="13" Margin="0,0,0,4"/>
                <Slider x:Name="MasterSlider" Minimum="0" Maximum="100" Value="50"
                        Margin="0,0,0,12" ValueChanged="MasterSlider_Changed"/>

                <TextBlock Text="Menu Music" Foreground="#C0B090" FontSize="13" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="MenuSlider" Minimum="0" Maximum="100" Value="50"
                            VerticalAlignment="Center" ValueChanged="MenuSlider_Changed"/>
                    <Button x:Name="MenuMuteBtn" Grid.Column="1" Content="🔊" FontSize="16"
                            Width="34" Height="30" Margin="8,0,0,0"
                            Background="#33FFFFFF" Foreground="#FFD700"
                            BorderThickness="0" Cursor="Hand"
                            Click="MenuMuteBtn_Click"/>
                </Grid>

                <TextBlock Text="Battle Music" Foreground="#C0B090" FontSize="13" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="BattleSlider" Minimum="0" Maximum="100" Value="50"
                            VerticalAlignment="Center" ValueChanged="BattleSlider_Changed"/>
                    <Button x:Name="BattleMuteBtnSettings" Grid.Column="1" Content="🔊" FontSize="16"
                            Width="34" Height="30" Margin="8,0,0,0"
                            Background="#33FFFFFF" Foreground="#FF6644"
                            BorderThickness="0" Cursor="Hand"
                            Click="BattleMuteBtnSettings_Click"/>
                </Grid>

                <Button Content="Close" Width="100" Height="34" Margin="0,8,0,0"
                        Style="{StaticResource RpgButton}" FontSize="13"
                        Click="CloseSettings_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="0" Style="{StaticResource RpgPanel}" Margin="10,8,10,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="NameTxt" Text="Hero" FontSize="20" FontWeight="Bold"
                               Cursor="Hand" MouseLeftButtonDown="NameTxt_Click">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FFD700" Offset="0"/>
                                <GradientStop Color="#FFA500" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Lv." Foreground="#B8860B" FontSize="15" FontWeight="Bold"/>
                    <TextBlock x:Name="LevelTxt" Text="1" Foreground="#FFD700" FontSize="15"
                               FontWeight="Bold" Margin="0,0,16,0"/>

                    <TextBlock Text="HP:" Foreground="#FF6666" FontSize="15" FontWeight="Bold"/>
                    <TextBlock x:Name="HpTxt" Text="100/100" Foreground="White" FontSize="15"
                               Margin="4,0,16,0"/>

                    <TextBlock Text="Mana:" Foreground="#6699FF" FontSize="15" FontWeight="Bold"/>
                    <TextBlock x:Name="ManaTxt" Text="3/3" Foreground="White" FontSize="15"
                               Margin="4,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="GoldTxt" Text="0" FontSize="17" FontWeight="Bold">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FFD700" Offset="0"/>
                                <GradientStop Color="#FFA500" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text=" Gold" Foreground="#B8860B" FontSize="13"
                               VerticalAlignment="Bottom" Margin="2,0,0,1"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="CITY HUB" FontSize="56" FontWeight="Bold"
                       HorizontalAlignment="Center">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFD700" Offset="0"/>
                        <GradientStop Color="#FFA500" Offset="0.5"/>
                        <GradientStop Color="#FFD700" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FFD700" BlurRadius="30" ShadowDepth="0" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="You are safe here. Prepare for your journey."
                       FontSize="16" Foreground="#8B8B7A"
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource RpgPanel}" Margin="10,0,10,10"
                Padding="10,8">
            <StackPanel HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">

                    <Button Content="⚔ JOURNEY" Width="200" Height="64" Margin="8"
                            Style="{StaticResource RpgRedButton}"
                            FontSize="17"
                            Click="JourneyButton_Click"/>

                    <Button Content="🏟 ARENA" Width="200" Height="64" Margin="8"
                            Style="{StaticResource RpgGreenButton}"
                            FontSize="17"
                            Click="ArenaButton_Click"/>

                    <Button Content="🛒 SHOP" Width="200" Height="64" Margin="8"
                            Style="{StaticResource RpgButton}"
                            FontSize="17"
                            Click="ShopButton_Click"/>

                    <Button Content="🍺 TAVERN" Width="200" Height="64" Margin="8"
                            Style="{StaticResource RpgButton}"
                            FontSize="17"
                            Click="TavernButton_Click"/>

                    <Button Content="🎒 INVENTORY" Width="200" Height="64" Margin="8"
                            Style="{StaticResource RpgTealButton}"
                            FontSize="17"
                            Click="InventoryButton_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                    <Button Content="✨ TALENTS" Width="200" Height="64" Margin="8"
                            Style="{StaticResource RpgButton}"
                            FontSize="17"
                            Click="TalentsButton_Click"/>

                    <Button Content="🔨 CRAFT" Width="200" Height="64" Margin="8"
                            Style="{StaticResource RpgButton}"
                            FontSize="17"
                            Click="CraftButton_Click"/>

                    <Button Content="💎 ENCHANT" Width="200" Height="64" Margin="8"
                            Style="{StaticResource RpgButton}"
                            FontSize="17"
                            Click="EnchantButton_Click"/>

                    <Button Content="🏆 ACHIEVEMENTS" Width="220" Height="64" Margin="8"
                            Style="{StaticResource RpgButton}"
                            FontSize="16"
                            Click="AchievementsButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
