<Window x:Class="CardRPG.UI.JourneyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Realm Selection"
        WindowState="Maximized"
        WindowStyle="None"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="Black">

    <Grid>
        <Image Source="Assets/bg_city.avif" Stretch="Fill"
               HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        <Rectangle Fill="#CC0A0A15"/>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="REALM SELECTION" FontSize="32" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,4">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFD700" Offset="0"/>
                        <GradientStop Color="#FFA500" Offset="0.5"/>
                        <GradientStop Color="#FFD700" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FFD700" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,0,0,10">
                <TextBlock Text="Level " Foreground="#B8860B" FontSize="15" FontWeight="Bold"/>
                <TextBlock x:Name="LevelTxt" Text="1" Foreground="#FFD700" FontSize="15" FontWeight="Bold"/>
                <TextBlock Text="   |   " Foreground="#555" FontSize="15"/>
                <TextBlock Text="XP: " Foreground="#8B8B7A" FontSize="15"/>
                <TextBlock x:Name="XpTxt" Text="0/120" Foreground="#AAA" FontSize="15"/>
                <TextBlock Text="   |   " Foreground="#555" FontSize="15"/>
                <TextBlock Text="Realms Unlocked: " Foreground="#8B8B7A" FontSize="15"/>
                <TextBlock x:Name="UnlockedTxt" Text="1/10" Foreground="#AAA" FontSize="15"/>
                <TextBlock Text="   |   " Foreground="#555" FontSize="15"/>
                <TextBlock Text="Difficulty: " Foreground="#B8860B" FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Button x:Name="DiffEasyBtn" Content="Easy" Width="70" Height="30" Margin="4,0"
                        FontSize="13" FontWeight="Bold"
                        Background="#33448844" Foreground="#88FF88"
                        BorderBrush="#55448844" BorderThickness="1" Cursor="Hand"
                        Click="DiffEasy_Click"/>
                <Button x:Name="DiffNormalBtn" Content="Normal" Width="80" Height="30" Margin="4,0"
                        FontSize="13" FontWeight="Bold"
                        Background="#33FFD700" Foreground="#FFD700"
                        BorderBrush="#55FFD700" BorderThickness="2" Cursor="Hand"
                        Click="DiffNormal_Click"/>
                <Button x:Name="DiffHardBtn" Content="Hard" Width="70" Height="30" Margin="4,0"
                        FontSize="13" FontWeight="Bold"
                        Background="#33FF4444" Foreground="#FF6644"
                        BorderBrush="#55FF4444" BorderThickness="1" Cursor="Hand"
                        Click="DiffHard_Click"/>
            </StackPanel>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <WrapPanel x:Name="RealmPanel" HorizontalAlignment="Center"
                           Orientation="Horizontal"/>
            </ScrollViewer>

            <Button Grid.Row="3" Content="BACK TO CITY" Width="220" Height="48"
                    Margin="0,12,0,0"
                    Style="{StaticResource RpgSubtleButton}"
                    FontSize="15"
                    Click="BackButton_Click"/>
        </Grid>
    </Grid>
</Window>
