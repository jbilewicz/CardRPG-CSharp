<Window x:Class="CardRPG.UI.PlayerStatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Character Stats" Height="660" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Black">

    <Grid>
        <Rectangle Fill="#EE0A0A15"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
            <Border Style="{StaticResource RpgPanel}" Padding="20">
                <StackPanel>
                    <TextBlock x:Name="PlayerNameTxt" Text="Hero" FontSize="28" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,4">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FFD700" Offset="0"/>
                                <GradientStop Color="#FFA500" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FFD700" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <TextBlock x:Name="LevelTxt" Text="Level 1" FontSize="16"
                               Foreground="#B8860B" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <TextBlock x:Name="XpTxt" Text="XP: 0/130" FontSize="13"
                               Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,16"/>

                    <Border Height="1" Background="#33FFD700" Margin="0,0,0,12"/>

                    <TextBlock Text="STATS" FontSize="14" FontWeight="Bold" Foreground="Gold"
                               Margin="0,0,0,8"/>

                    <Grid Margin="10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="HP" Foreground="#E86060" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="HpVal" Foreground="White" FontSize="14" FontWeight="Bold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Mana" Foreground="MediumPurple" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ManaVal" Foreground="White" FontSize="14" FontWeight="Bold"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Strength" Foreground="#E8C080" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="StrVal" Foreground="White" FontSize="14" FontWeight="Bold"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Agility" Foreground="#80E880" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="AgiVal" Foreground="White" FontSize="14" FontWeight="Bold"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Intelligence" Foreground="#8080E8" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="IntVal" Foreground="White" FontSize="14" FontWeight="Bold"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Armor" Foreground="#80C0C0" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="ArmorVal" Foreground="White" FontSize="14" FontWeight="Bold"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Equipped Weapon" Foreground="#FFAA44" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="WeaponVal" Foreground="White" FontSize="14" FontWeight="Bold"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Deck Size" Foreground="#FFCC44" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" x:Name="DeckVal" Foreground="White" FontSize="14" FontWeight="Bold"/>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Gold" Foreground="#FFD700" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Grid.Row="8" Grid.Column="1" x:Name="GoldVal" Foreground="White" FontSize="14" FontWeight="Bold"/>
                    </Grid>

                    <Border Height="1" Background="#33FFD700" Margin="0,12,0,12"/>

                    <TextBlock x:Name="RealmTxt" Text="Realms Unlocked: 1/10"
                               Foreground="#888" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TalentTxt" Text="Talent Points: 0"
                               Foreground="#FFCC44" FontSize="13" HorizontalAlignment="Center"/>

                    <Border Height="1" Background="#33CC44FF" Margin="0,12,0,12"/>

                    <TextBlock Text="STATISTICS" FontSize="14" FontWeight="Bold" Margin="0,0,0,8">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#CC44FF" Offset="0"/>
                                <GradientStop Color="#8844FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>

                    <Grid Margin="10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="26"/>
                            <RowDefinition Height="26"/>
                            <RowDefinition Height="26"/>
                            <RowDefinition Height="26"/>
                            <RowDefinition Height="26"/>
                            <RowDefinition Height="26"/>
                            <RowDefinition Height="26"/>
                            <RowDefinition Height="26"/>
                            <RowDefinition Height="26"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Damage" Foreground="#FF6666" FontSize="13"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="StatDmgVal" Foreground="White" FontSize="13" FontWeight="Bold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Enemies Killed" Foreground="#FF9966" FontSize="13"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="StatKillsVal" Foreground="White" FontSize="13" FontWeight="Bold"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Elites Slain" Foreground="#FFAA44" FontSize="13"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="StatElitesVal" Foreground="White" FontSize="13" FontWeight="Bold"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Bosses Slain" Foreground="#FF4444" FontSize="13"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="StatBossesVal" Foreground="White" FontSize="13" FontWeight="Bold"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Realms Completed" Foreground="#44DD44" FontSize="13"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="StatRealmsVal" Foreground="White" FontSize="13" FontWeight="Bold"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Highest Combo" Foreground="#FF8800" FontSize="13"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="StatComboVal" Foreground="White" FontSize="13" FontWeight="Bold"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Highest Hit" Foreground="#FF3333" FontSize="13"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="StatHitVal" Foreground="White" FontSize="13" FontWeight="Bold"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Total Gold Earned" Foreground="#FFD700" FontSize="13"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" x:Name="StatGoldVal" Foreground="White" FontSize="13" FontWeight="Bold"/>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Cards Enchanted" Foreground="#CC44FF" FontSize="13"/>
                        <TextBlock Grid.Row="8" Grid.Column="1" x:Name="StatEnchVal" Foreground="White" FontSize="13" FontWeight="Bold"/>
                    </Grid>

                    <Button Content="Close" Width="120" Height="36" Margin="0,16,0,0"
                            Style="{StaticResource RpgSubtleButton}"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
