<Window x:Class="CardRPG.UI.TalentTreeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Talent Tree" Height="720" Width="1050"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Black">

    <Grid>
        <Image Source="Assets/bg_city.avif" Stretch="Fill"
               HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        <Rectangle Fill="#EE0A0A15"/>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="TALENT TREE" FontSize="30" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,4">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFD700" Offset="0"/>
                        <GradientStop Color="#FFA500" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FFD700" BlurRadius="14" ShadowDepth="0" Opacity="0.4"/>
                </TextBlock.Effect>
            </TextBlock>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,0,0,10">
                <TextBlock Text="Talent Points: " Foreground="#B8860B" FontSize="16" FontWeight="Bold"/>
                <TextBlock x:Name="PointsTxt" Text="0" Foreground="#FFD700" FontSize="18"
                           FontWeight="Bold">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FFD700" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource RpgPanel}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="WARRIOR" FontSize="18" FontWeight="Bold"
                                   Foreground="#FF6644" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FF4422" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <StackPanel x:Name="WarriorPanel"/>
                    </DockPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource RpgPanel}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="ROGUE" FontSize="18" FontWeight="Bold"
                                   Foreground="#44FF44" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#22FF22" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <StackPanel x:Name="RoguePanel"/>
                    </DockPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource RpgPanel}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="MAGE" FontSize="18" FontWeight="Bold"
                                   Foreground="#6699FF" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#4488FF" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <StackPanel x:Name="MagePanel"/>
                    </DockPanel>
                </Border>
            </Grid>

            <Border Grid.Row="3" Style="{StaticResource RpgPanel}"
                    Padding="10,6" Margin="0,10,0,0">
                <DockPanel>
                    <TextBlock x:Name="StatusTxt" Foreground="LimeGreen" FontSize="13"
                               VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="Close" Width="90" Height="38"
                            Style="{StaticResource RpgSubtleButton}"
                            Click="CloseButton_Click"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
