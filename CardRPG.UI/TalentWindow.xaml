<Window x:Class="CardRPG.UI.TalentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Talent Tree"
        WindowState="Maximized"
        WindowStyle="None"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="Black">

    <Grid>
        <Image Source="Assets/bg_city.avif" Stretch="Fill"/>
        <Rectangle Fill="#DD0A0A15"/>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="TALENT TREE" FontSize="28" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,4">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFD700" Offset="0"/>
                        <GradientStop Color="#FFA500" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FFD700" BlurRadius="16" ShadowDepth="0" Opacity="0.4"/>
                </TextBlock.Effect>
            </TextBlock>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                <TextBlock Text="Available Points: " Foreground="#BBAA88" FontSize="16" FontWeight="Bold"/>
                <TextBlock x:Name="PointsTxt" Text="0" Foreground="#FFD700" FontSize="18" FontWeight="Bold">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FFD700" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource RpgPanel}" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="STRENGTH" FontSize="18" FontWeight="Bold"
                                   Foreground="#FF6644" HorizontalAlignment="Center" Margin="0,0,0,4">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FF4422" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="+1 base damage per point" Foreground="#886644" FontSize="10"
                                   HorizontalAlignment="Center" Margin="0,0,0,12" TextWrapping="Wrap" TextAlignment="Center"/>
                        <TextBlock x:Name="StrTxt" Text="10" Foreground="White" FontSize="32" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <Button Content="+ STR" Height="42" Style="{StaticResource RpgRedButton}"
                                FontSize="14" Click="AddStr_Click"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource RpgPanel}" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="AGILITY" FontSize="18" FontWeight="Bold"
                                   Foreground="#44FF44" HorizontalAlignment="Center" Margin="0,0,0,4">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#22FF22" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="+0.5% dodge, +0.5 armor per point" Foreground="#448844" FontSize="10"
                                   HorizontalAlignment="Center" Margin="0,0,0,12" TextWrapping="Wrap" TextAlignment="Center"/>
                        <TextBlock x:Name="AgiTxt" Text="10" Foreground="White" FontSize="32" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <Button Content="+ AGI" Height="42" Style="{StaticResource RpgGreenButton}"
                                FontSize="14" Click="AddAgi_Click"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource RpgPanel}" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="INTELLIGENCE" FontSize="18" FontWeight="Bold"
                                   Foreground="#4488FF" HorizontalAlignment="Center" Margin="0,0,0,4">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#2266FF" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="+1% crit chance per point" Foreground="#446688" FontSize="10"
                                   HorizontalAlignment="Center" Margin="0,0,0,12" TextWrapping="Wrap" TextAlignment="Center"/>
                        <TextBlock x:Name="IntTxt" Text="10" Foreground="White" FontSize="32" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <Button Content="+ INT" Height="42" Style="{StaticResource RpgTealButton}"
                                FontSize="14" Click="AddInt_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="3" Style="{StaticResource RpgPanel}" Padding="10,6" Margin="0,12,0,0">
                <DockPanel>
                    <TextBlock x:Name="StatusTxt" Foreground="LimeGreen" FontSize="13" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="Close" Width="100" Height="42" FontSize="14"
                            Style="{StaticResource RpgSubtleButton}" Click="CloseBtn_Click"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
