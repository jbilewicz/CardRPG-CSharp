<Window x:Class="CardRPG.UI.TavernWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tavern"
        WindowState="Maximized"
        WindowStyle="None"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="Black">

    <Grid>
        <Image Source="Assets/bg_tavern.png" Stretch="Fill"
               HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        <Rectangle Fill="#CC0A0808"/>

        <Grid Margin="24,18,24,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="THE RUSTY FLAGON"
                       FontSize="30" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,4">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFD700" Offset="0"/>
                        <GradientStop Color="#FFA500" Offset="0.5"/>
                        <GradientStop Color="#FFD700" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FFD700" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Grid.Row="1" Text="Rest, eat, and pick up bounties from the quest board."
                       FontSize="13" Foreground="#BBAA88"
                       HorizontalAlignment="Center" Margin="0,0,0,14"/>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Rest & Stats -->
                <Border Grid.Column="0" Style="{StaticResource RpgPanel}"
                        Padding="20,14" MinWidth="250" VerticalAlignment="Top">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                            <TextBlock x:Name="HpTxt" Text="HP: 100/100"
                                       Foreground="LightGreen" FontSize="16" FontWeight="Bold">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="LimeGreen" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <TextBlock x:Name="GoldTxt" Text="Gold: 0"
                                       FontSize="16" FontWeight="Bold">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FFD700" Offset="0"/>
                                        <GradientStop Color="#FFA500" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>

                        <Button Content="Meal - Heal 30 HP  (10g)"
                                Width="220" Height="44" Margin="0,0,0,8"
                                Style="{StaticResource RpgButton}" FontSize="13"
                                Click="MealButton_Click"/>
                        <Button Content="Full Rest - Heal fully  (30g)"
                                Width="220" Height="44"
                                Style="{StaticResource RpgGreenButton}" FontSize="13"
                                Click="RestButton_Click"/>
                    </StackPanel>
                </Border>

                <!-- Right: Quest Board -->
                <Border Grid.Column="2" Style="{StaticResource RpgPanel}" Padding="12,10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="QUEST BOARD" Foreground="#FFCC44"
                                   FontSize="16" FontWeight="Bold" Margin="0,0,0,8">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FFD700" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="QuestList"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <Border Grid.Row="3" Style="{StaticResource RpgPanel}"
                    Padding="10,6" Margin="0,12,0,0">
                <DockPanel>
                    <TextBlock x:Name="StatusTxt" Foreground="LimeGreen" FontSize="14"
                               VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="Leave" Width="110" Height="42" FontSize="14"
                            Style="{StaticResource RpgSubtleButton}"
                            Click="LeaveButton_Click"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
