<Window x:Class="CardRPG.UI.VictoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Victory"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        Width="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border CornerRadius="12" Padding="0" Margin="20"
            BorderThickness="2">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#B8860B" Offset="0"/>
                <GradientStop Color="#FFD700" Offset="0.5"/>
                <GradientStop Color="#B8860B" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#F01A1A2E" Offset="0"/>
                <GradientStop Color="#F00D0D14" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#FFD700" BlurRadius="30" ShadowDepth="0" Opacity="0.4"/>
        </Border.Effect>

        <StackPanel Margin="28,24,28,20">

            <!-- Title -->
            <TextBlock x:Name="TitleTxt" Text="VICTORY" FontSize="30" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,4">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFD700" Offset="0"/>
                        <GradientStop Color="#FFA500" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FFD700" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- Subtitle -->
            <TextBlock x:Name="SubtitleTxt" Text="" FontSize="14"
                       Foreground="#8B8B7A" HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

            <!-- Divider -->
            <Border Height="1" Margin="0,0,0,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#FFD700" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Rewards panel -->
            <StackPanel x:Name="RewardsPanel" Margin="0,0,0,10"/>

            <!-- Extra info (level up, new realm, etc.) -->
            <StackPanel x:Name="ExtraPanel" Margin="0,0,0,10"/>

            <!-- Summary section (for realm complete) -->
            <Border x:Name="SummaryBorder" Visibility="Collapsed"
                    CornerRadius="6" Padding="12,10" Margin="0,4,0,10"
                    Background="#22FFD700" BorderBrush="#44FFD700" BorderThickness="1">
                <StackPanel x:Name="SummaryPanel"/>
            </Border>

            <!-- Continue button -->
            <Button Content="CONTINUE" Width="180" Height="48"
                    FontSize="16" Margin="0,6,0,0"
                    Style="{StaticResource RpgButton}"
                    Click="ContinueButton_Click"/>
        </StackPanel>
    </Border>
</Window>
